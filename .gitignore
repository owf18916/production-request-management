# Git Ignore

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Composer
vendor/
composer.lock

# Logs
storage/logs/
*.log

# PHP Temporary Files
*.php~
*.phtml~

# Operating System
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Node (if using npm for frontend tools)
node_modules/
npm-debug.log
yarn-error.log

# Build artifacts
dist/
build/

# Cache files
.cache/
*.cache

# Database backups
*.sql.bak
*.sql.gz

# Uploads (if applicable)
public/uploads/
storage/uploads/

# Session files
storage/sessions/

# Temporary files
tmp/
temp/

# Testing
tests/coverage/
.phpunit.result.cache

# Config files with sensitive data
config/secrets.php

# SSL certificates (if stored locally)
*.pem
*.crt
*.key
